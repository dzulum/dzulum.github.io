---
layout: none
---
[
  {% for post in site.posts limit:3 %}
    {
      "title": "{{ post.title | escape }}",
      "url": "{{ site.url }}{{ post.url }}",
      "date": "{{ post.date | date: "%d/%m/%Y" }}",
      "image": "{{ post.image }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]